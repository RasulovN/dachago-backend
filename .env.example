# --- Ma'lumotlar bazasi (lokal PostgreSQL 18) ---
# Formatni o'zingizning parolingiz bilan to'ldiring:
DATABASE_URL="postgresql://postgres:PAROL@localhost:5432/dachago?schema=public"

# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# --- JWT ---
JWT_ACCESS_SECRET="super-maxfiy-access-kalit-ozgartiring"
JWT_REFRESH_SECRET="super-maxfiy-refresh-kalit-ozgartiring"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# --- CORS (frontend manzillari) ---
WEB_ORIGIN="https://dachago-landing.vercel.app/" 
LANDING_ORIGIN="https://dachago-client.vercel.app/"

# --- Fayllar ---
UPLOAD_DIR="../../uploads"
PUBLIC_BASE_URL="http://localhost:3000"

# --- Payme Merchant API ---
# Real merchant kalitlaringizni bu yerga qo'ying:
PAYME_MERCHANT_ID="sizning_merchant_id"
PAYME_KEY="sizning_kassa_kaliti"
PAYME_CHECKOUT_URL="https://checkout.paycom.uz"
# Sandbox uchun: https://checkout.test.paycom.uz
