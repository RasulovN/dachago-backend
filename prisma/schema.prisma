generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  SELLER
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

// Barcha e'lon turlari uchun umumiy moderatsiya holati
enum ListingStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  ARCHIVED
}

// Xizmat turi — bron va qulayliklar lug'atida ishlatiladi
enum ListingType {
  DACHA
  HOTEL
  CAR
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum FuelType {
  PETROL
  DIESEL
  GAS
  HYBRID
  ELECTRIC
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  NOT_REQUIRED
  AWAITING
  PAID
  REFUNDED
}

enum DepositType {
  FIXED
  PERCENT
}

model User {
  id        String     @id @default(cuid())
  phone     String     @unique
  email     String?
  password  String
  role      UserRole   @default(SELLER)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  sellerProfile SellerProfile?
  dachas        Dacha[]
  hotels        Hotel[]
  cars          Car[]
  refreshTokens RefreshToken[]
  payouts       Payout[]

  @@index([role, status])
}

model SellerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  companyName     String?
  passportInfo    String
  address         String
  avatar          String?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Hudud/zona — barcha modullar uchun umumiy reference lug'at
model Zone {
  id       String  @id @default(cuid())
  slug     String  @unique
  nameUz   String
  nameRu   String
  nameEn   String
  descUz   String  @default("")
  descRu   String  @default("")
  descEn   String  @default("")
  image    String?
  isActive Boolean @default(true)
  order    Int     @default(0)

  dachas    Dacha[]
  hotels    Hotel[]
  cars      Car[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Qulaylik — umumiy lug'at; `types` qaysi modullarga tegishliligini belgilaydi
model Amenity {
  id     String        @id @default(cuid())
  icon   String
  nameUz String
  nameRu String
  nameEn String
  order  Int           @default(0)
  types  ListingType[] @default([DACHA, HOTEL])

  dachas    DachaAmenity[]
  hotels    HotelAmenity[]
  cars      CarAmenity[]
  createdAt DateTime       @default(now())
}

// ==================== DACHA moduli ====================

model Dacha {
  id              String        @id @default(cuid())
  slug            String        @unique
  sellerId        String
  seller          User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  zoneId          String
  zone            Zone          @relation(fields: [zoneId], references: [id])
  titleUz         String
  titleRu         String
  titleEn         String
  descUz          String
  descRu          String
  descEn          String
  pricePerDay     Int
  priceWeekend    Int?
  capacity        Int
  rooms           Int
  area            Int?
  lat             Float
  lng             Float
  address         String
  status          ListingStatus @default(PENDING)
  rejectionReason String?
  depositEnabled  Boolean       @default(false)
  depositType     DepositType   @default(FIXED)
  depositValue    Int           @default(0)
  checkInTime     String        @default("14:00")
  checkOutTime    String        @default("12:00")
  viewsCount      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  images    DachaImage[]
  videos    DachaVideo[]
  amenities DachaAmenity[]
  bookings  Booking[]

  @@index([status])
  @@index([zoneId])
  @@index([sellerId])
}

model DachaImage {
  id       String @id @default(cuid())
  dachaId  String
  dacha    Dacha  @relation(fields: [dachaId], references: [id], onDelete: Cascade)
  url      String
  thumbUrl String
  order    Int    @default(0)

  @@index([dachaId])
}

model DachaVideo {
  id      String @id @default(cuid())
  dachaId String
  dacha   Dacha  @relation(fields: [dachaId], references: [id], onDelete: Cascade)
  url     String
  size    Int
  order   Int    @default(0)

  @@index([dachaId])
}

model DachaAmenity {
  dachaId   String
  dacha     Dacha   @relation(fields: [dachaId], references: [id], onDelete: Cascade)
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([dachaId, amenityId])
}

// ==================== HOTEL moduli ====================

model Hotel {
  id                String        @id @default(cuid())
  slug              String        @unique
  sellerId          String
  seller            User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  zoneId            String
  zone              Zone          @relation(fields: [zoneId], references: [id])
  titleUz           String
  titleRu           String
  titleEn           String
  descUz            String
  descRu            String
  descEn            String
  starRating        Int           @default(3)
  breakfastIncluded Boolean       @default(false)
  hasConference     Boolean       @default(false)
  // Eng arzon xona narxi (denormalizatsiya — xona CRUD'da qayta hisoblanadi)
  priceFrom         Int           @default(0)
  lat               Float
  lng               Float
  address           String
  status            ListingStatus @default(PENDING)
  rejectionReason   String?
  depositEnabled    Boolean       @default(false)
  depositType       DepositType   @default(FIXED)
  depositValue      Int           @default(0)
  checkInTime       String        @default("14:00")
  checkOutTime      String        @default("12:00")
  viewsCount        Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  images    HotelImage[]
  videos    HotelVideo[]
  amenities HotelAmenity[]
  rooms     HotelRoom[]

  @@index([status])
  @@index([zoneId])
  @@index([sellerId])
}

model HotelVideo {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  url     String
  size    Int
  order   Int    @default(0)

  @@index([hotelId])
}

// Mehmonxona xona turi — narx va sig'im xonada; totalRooms = shu turdagi xonalar soni
model HotelRoom {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  nameUz        String
  nameRu        String
  nameEn        String
  capacity      Int
  pricePerNight Int
  priceWeekend  Int?
  totalRooms    Int      @default(1)
  area          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings Booking[]

  @@index([hotelId])
}

model HotelImage {
  id       String @id @default(cuid())
  hotelId  String
  hotel    Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  url      String
  thumbUrl String
  order    Int    @default(0)

  @@index([hotelId])
}

model HotelAmenity {
  hotelId   String
  hotel     Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([hotelId, amenityId])
}

// ==================== CAR moduli ====================

model Car {
  id              String        @id @default(cuid())
  slug            String        @unique
  sellerId        String
  seller          User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  zoneId          String
  zone            Zone          @relation(fields: [zoneId], references: [id])
  titleUz         String
  titleRu         String
  titleEn         String
  descUz          String
  descRu          String
  descEn          String
  brand           String
  carModel        String
  year            Int
  seats           Int
  transmission    Transmission  @default(AUTOMATIC)
  fuelType        FuelType      @default(PETROL)
  driverIncluded  Boolean       @default(true)
  routeInfo       String?
  pricePerDay     Int
  priceWeekend    Int?
  lat             Float
  lng             Float
  address         String
  status          ListingStatus @default(PENDING)
  rejectionReason String?
  depositEnabled  Boolean       @default(false)
  depositType     DepositType   @default(FIXED)
  depositValue    Int           @default(0)
  viewsCount      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  images    CarImage[]
  videos    CarVideo[]
  amenities CarAmenity[]
  bookings  Booking[]

  @@index([status])
  @@index([zoneId])
  @@index([sellerId])
  @@index([brand])
}

model CarVideo {
  id    String @id @default(cuid())
  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
  url   String
  size  Int
  order Int    @default(0)

  @@index([carId])
}

model CarImage {
  id       String @id @default(cuid())
  carId    String
  car      Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
  url      String
  thumbUrl String
  order    Int    @default(0)

  @@index([carId])
}

model CarAmenity {
  carId     String
  car       Car     @relation(fields: [carId], references: [id], onDelete: Cascade)
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([carId, amenityId])
}

// ==================== BOOKING (umumiy entity, polymorphic FK) ====================

model Booking {
  id          String      @id @default(cuid())
  code        String      @unique
  listingType ListingType @default(DACHA)
  // Har bron faqat bitta xizmatga bog'lanadi — turga mos FK to'ldiriladi
  dachaId     String?
  dacha       Dacha?      @relation(fields: [dachaId], references: [id], onDelete: Cascade)
  hotelRoomId String?
  hotelRoom   HotelRoom?  @relation(fields: [hotelRoomId], references: [id], onDelete: Cascade)
  carId       String?
  car         Car?        @relation(fields: [carId], references: [id], onDelete: Cascade)
  // Mehmonxona broni uchun: nechta xona band qilingan
  roomsCount  Int         @default(1)

  guestName     String
  guestPhone    String
  checkIn       DateTime
  checkOut      DateTime
  guestsCount   Int
  totalPrice    Int
  depositAmount Int?
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(NOT_REQUIRED)
  note          String?
  expiresAt     DateTime?
  // Sellerga zaklad to'lovi (payout)
  sellerPaidOut Boolean       @default(false)
  paidOutAt     DateTime?
  payoutId      String?
  payout        Payout?       @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  transactions PaymeTransaction[]

  @@index([dachaId, status])
  @@index([hotelRoomId, status])
  @@index([carId, status])
  @@index([listingType])
  @@index([status])
  @@index([payoutId])
}

// Sellerga zaklad mablag'ini o'tkazish hujjati — bir to'lov bir nechta bronni qamrab oladi
model Payout {
  id        String    @id @default(cuid())
  sellerId  String
  seller    User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  amount    Int
  note      String    @default("")
  createdAt DateTime  @default(now())
  bookings  Booking[]

  @@index([sellerId])
}

model PaymeTransaction {
  id          String   @id @default(cuid())
  paymeId     String   @unique
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount      Int
  state       Int      @default(1)
  createTime  BigInt
  performTime BigInt   @default(0)
  cancelTime  BigInt   @default(0)
  reason      Int?
  createdAt   DateTime @default(now())

  @@index([bookingId])
}

model SiteSettings {
  id        Int      @id @default(1)
  phone     String   @default("+998 78 113 00 13")
  email     String   @default("info@sayohatgo.uz")
  telegram  String   @default("https://t.me/sayohatgo_uz")
  instagram String   @default("https://instagram.com/sayohatgo.uz")
  youtube   String   @default("https://youtube.com/@sayohatgo")
  updatedAt DateTime @default(now()) @updatedAt
}
